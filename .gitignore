# =============================================================================
# Music Recommender - .gitignore
# =============================================================================

# ----- Python -----
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# ----- Virtual Environment -----
.venv/
.venv311/
venv/
ENV/
env/

# ----- IDE -----
.vscode/
.idea/
*.swp
*.swo
*~

# ----- Jupyter -----
.ipynb_checkpoints/
*.ipynb

# =============================================================================
# LARGE FILES - EXCLUDED TO REDUCE REPO SIZE
# =============================================================================

# ----- Dataset Files (1-2GB each) -----
dataset/
*.json
!package.json
!tsconfig.json

# ----- Processed Data (Generated) -----
data/processed/train.csv
data/processed/val.csv
data/processed/test.csv
data/processed/embeddings/

# ----- Audio Model Processed Data (Generated, large) -----
data/processed/audio_train.csv
data/processed/audio_val.csv
data/processed/audio_test.csv
data/processed/tracks/

# ----- Model Files (Large) -----
models/*.pth
models/*.bin
models/*.npy
models/*.pkl
models/*.index

# ----- Log Files -----
*.log
project_implementation_log.txt
hybrid_music_engine/project_implementation_log.txt

# ----- Temp / Debug files -----
test_output.txt
web_app/debug_imports.py

# =============================================================================
# FILES TO KEEP (whitelist overrides above patterns)
# =============================================================================
# Model 1 config files (small, needed at runtime)
!models/audio_stats.json
!models/metadata_vocab.json
!data/processed/dataset_info.json

# Model 2 config files (small, needed at runtime)
!models/tracks_stats.json

# autoencoder_model2.pth is tiny (~11KB), commit directly
!models/autoencoder_model2.pth

# ----- Environment / Secrets -----
.env
.env.*

# ----- OS Files -----
.DS_Store
Thumbs.db
desktop.ini

# ----- Temporary Files -----
*.tmp
*.temp
*.bak

models/bert_cache/

# ----- Visualizations (local only, not needed on HF) -----
visualizations/
NotebookLM_Source_Files/

# ----- SQLite Database (local dev only, PostgreSQL used in prod) -----
*.db
*.sqlite
*.sqlite3

# ----- Agent config (local tooling) -----
.agent/
